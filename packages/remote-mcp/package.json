  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.6.0",
    "sendkit-core": "^0.1.0",
    "sendkit-mcp": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/bun": "latest"
  }
}
