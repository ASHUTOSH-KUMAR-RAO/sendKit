{
  "name": "sendkit-wrokspace",
  "private": "true",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run packages/remote-mcp/src/index.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:ci": "oxlint . --deny correctness --deny suspicious",
    "build": "bun run --cwd packages/core build && bun run --cwd packages/cli build && bun run --cwd packages/local-mcp build && bun run --cwd packages/remote-mcp build",
    "clean": "rm -rf packages/*/dist"
  },
 "devDependencies": {
  "oxlint": "^1.73.0",
  "typescript": "^5.7.0"
}
}
