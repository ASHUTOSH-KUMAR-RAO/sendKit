
{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "node",
    "promise"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "rules": {
    "no-console": "off",
    "typescript/no-explicit-any": "warn",
    "promise/no-nesting": "warn",
    "eqeqeq": "error"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "*.tsbuildinfo",
    "bun.lock",
    "*.db"
  ]
}
